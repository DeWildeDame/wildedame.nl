---
import { getCollection } from "astro:content";
const photosData = await getCollection("photos");

import { Image } from "astro:assets";

import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

import Metadata from "../../components/photos/metadata.astro";

const posts = (await getCollection("photos")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body class="photos overview">
		<Header />
		<main>
			<section>
				<div class="photo">
					{
						posts.map((post) => (
							<a href={`/photos/${post.id}/`}>
								<div>
									{post.data.image && (
										<Image
											height={320}
											width={500}
											src={post.data.image}
											alt={post.data.title}
										/>
									)}
									<Metadata
										pubDate={post.data.pubDate}
										updatedDate={post.data.updatedDate}
										createdDate={post.data.createdDate}
										location={post.data.location}
										title={post.data.title}
										locationName={post.data.locationName}
										make={post.data.make}
										model={post.data.model}
										iso={post.data.iso}
										meteringMode={post.data.meteringMode}
										exposureCompensation={
											post.data.exposureCompensation
										}
										exposureProgram={
											post.data.exposureProgram
										}
										exposureTime={post.data.exposureTime}
										fNumber={post.data.fNumber}
										focalLengthIn35mmFormat={
											post.data.focalLengthIn35mmFormat
										}
										focalLength={post.data.focalLength}
										lensMake={post.data.lensMake}
										lensModel={post.data.lensModel}
										maxApertureValue={
											post.data.maxApertureValue
										}
									/>
								</div>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
