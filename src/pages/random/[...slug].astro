---
import { type CollectionEntry, getCollection, render } from "astro:content";
import TerminalPost from "../../layouts/TerminalPost.astro";

export async function getStaticPaths() {
	const posts = await getCollection("terminal");
	return posts.map((post: any) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<"terminal">;

const post = Astro.props;
const { Content } = await render(post);
---

<TerminalPost {...post.data}>
	<Content />
</TerminalPost>
