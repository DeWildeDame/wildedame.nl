			Monoid has to be one of my favorite fonts out here!

			*/
			@font-face {
				font-family: "monoidbold";
				src:
					url("/assets/fonts/monoid/monoid-bold-webfont.woff2")
						format("woff2"),
					url("/assets/fonts/monoid/monoid-bold-webfont.woff")
						format("woff");
				font-weight: normal;
				font-style: normal;
			}

			@font-face {
				font-family: "monoiditalic";
				src:
					url("/assets/fonts/monoid/monoid-italic-webfont.woff2")
