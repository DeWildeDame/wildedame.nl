---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog")).sort(
	(a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			/*! 
			Generated by Font Squirrel (https://www.fontsquirrel.com) on April 3, 2026 
			Thanks Font Squirrel I have been using your services for my projects!
			
			Shout out to Andreas (https://larsenwork.com/) as well,
			Monoid has to be one of my favorite fonts out here!

			*/
			@font-face {
				font-family: "monoidbold";
				src:
					url("/assets/fonts/monoid/monoid-bold-webfont.woff2")
						format("woff2"),
					url("/assets/fonts/monoid/monoid-bold-webfont.woff")
						format("woff");
				font-weight: normal;
				font-style: normal;
			}

			@font-face {
				font-family: "monoiditalic";
				src:
					url("/assets/fonts/monoid/monoid-italic-webfont.woff2")
						format("woff2"),
					url("/assets/fonts/monoid/monoid-italic-webfont.woff")
						format("woff");
				font-weight: normal;
				font-style: normal;
			}

			@font-face {
				font-family: "monoidregular";
				src:
					url("/assets/fonts/monoid/monoid-regular-webfont.woff2")
						format("woff2"),
					url("/assets/fonts/monoid/monoid-regular-webfont.woff")
						format("woff");
				font-weight: normal;
				font-style: normal;
			}

			@font-face {
				font-family: "monoidretina";
				src:
					url("/assets/fonts/monoid/monoid-retina-webfont.woff2")
						format("woff2"),
					url("/assets/fonts/monoid/monoid-retina-webfont.woff")
						format("woff");
				font-weight: normal;
				font-style: normal;
			}

			body {
				font-family: "monoidregular", sans-serif;
				margin: 0;
				padding: 0;
				text-align: left;
				background: var(--dark-background);
				background-size: 100%;

				/* Make sure the background covers the entire viewport */
				background-attachment: fixed;

				/* Ensure the body takes up the full height of the viewport */
				width: 100%;
				height: 100vh;

				/* We don't like breaking words in the middle of a line, but we do want to break long words that would otherwise overflow */
				word-wrap: break-word;
				overflow-wrap: break-word;

				/* Set the default text color and size */
				color: rgb(var(--text-color));

				/* Nice and readable line height */
				font-size: 20px;
				line-height: 1.7;
			}

			main {
				width: 100%;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				margin-bottom: 0.5rem;
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				dasasdsadasd
				<ul>
					{
						posts.map((post: any) =>
							/*<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image
											width={720}
											height={360}
											src={post.data.heroImage}
											alt=""
										/>
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate
											date={post.data.pubDate}
										/>
									</p>
								</a>
							</li>*/
							console.log(post),
						)
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
