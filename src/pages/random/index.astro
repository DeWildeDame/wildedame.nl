				font-weight: normal;
				font-style: normal;
			}

			@font-face {
				font-family: "monoidretina";
				src:
					url("/assets/fonts/monoid/monoid-retina-webfont.woff2")
						format("woff2"),
					url("/assets/fonts/monoid/monoid-retina-webfont.woff")
						format("woff");
				font-weight: normal;
				font-style: normal;
			}

			body {
				background: var(--void-0);
				color: var(--void-6);
				font-family: "monoidregular", monospace;
				padding: 1.5rem;
				border-radius: 8px;
				line-height: 1.6;
				font-size: 0.95rem;

				/* Optional subtle scanlines */
				background-image: repeating-linear-gradient(
					to bottom,
					rgba(255, 255, 255, 0.03) 0,
					rgba(255, 255, 255, 0.03) 1px,
					transparent 1px,
					transparent 3px
				);
			}

