---
import { type CollectionEntry, getCollection, render } from "astro:content";
import PortfolioPost from "../../layouts/PortfolioPost.astro";

export async function getStaticPaths() {
	const posts = await getCollection("portfolio");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<"portfolio">;

const portfolio = Astro.props;
const { Content } = await render(portfolio);
---

<PortfolioPost {...portfolio.data}>
	<Content />
</PortfolioPost>
