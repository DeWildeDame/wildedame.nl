---
const { logo, role, company, companyUrl, period, description } = Astro.props;
---

<div class="card">
	<div class="card-title">
		<div class="logo">
			<img src={logo} width="100" height="100" alt={company} />
		</div>

		<div>
			<h5>
				{role}<br />
				<small>
					{
						companyUrl ? (
							<a href={companyUrl} target="_blank">
								{company}
							</a>
						) : (
							company
						)
					}
				</small>
			</h5>
			<h6>({period})</h6>
		</div>
	</div>
	<p
		class="card-description"
		set:html={description.replace(/\n/g, "<br/>")}
	/>
	<hr />
</div>

<style>
	/* card */
	.card {
	}
	.card-title {
		display: flex;
		justify-content: left; /* horizontal centering */
		align-items: top; /* vertical centering */
		padding: 0 1em;
		gap: 1em;
	}
	.card .logo {
		width: 100px;
	}
	.card-description {
		margin-top: -1em;
		padding: 0 1em;
	}
</style>
