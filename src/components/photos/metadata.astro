---
import formatExposureTime from "./formatExposureTime";

interface Props {
	pubDate: Date;
	updatedDate: Date | undefined;
	createdDate: Date | undefined;
	location: string[] | undefined;
	locationName: string | undefined;
	make: string | undefined;
	model: string | undefined;
	orientation: string | undefined;
	iso: number | undefined;
	meteringMode: string | undefined;
	exposureTime: number | undefined;
	exposureProgram: string | undefined;
	exposureCompensation: number | undefined;
	fNumber: number | undefined;
	focalLength: string | undefined;
	focalLengthIn35mmFormat: string | undefined;
	lensMake: string | undefined;
	lensModel: string | undefined;
	maxApertureValue: number | undefined;
}
const {
	pubDate,
	updatedDate,
	createdDate,
	location,
	locationName,
	make,
	model,
	orientation,
	iso,
	meteringMode,
	exposureCompensation,
	exposureProgram,
	exposureTime,
	fNumber,
	focalLength,
	focalLengthIn35mmFormat,
	lensMake,
	lensModel,
	maxApertureValue,
} = Astro.props;

import FormattedDate from "../FormattedDate.astro";
---

<table class="photo-metadata">
	<tbody>
		<tr>
			<td class="icon"
				><img
					src="/assets/img/icons/camera.svg"
					alt="Camera and lens"
				/>
			</td>
			<td colspan="4">
				<strong class="accent">{model}</strong>
				<br />
				{lensModel}
			</td>
		</tr>
		<tr>
			<td class="small icon">
				<img src="/assets/img/icons/iso.svg" alt="ISO" />
			</td>
			<td>
				{iso}
			</td>
			<td class="small icon">
				<img src="/assets/img/icons/aperture.svg" alt="aperture" />
			</td>
			<td>
				ƒ/{fNumber}
			</td>
			<td class="small icon">
				<img
					src="/assets/img/icons/shutterspeed.svg"
					alt="Shutter speed"
				/>
			</td>
			<td>
				{exposureTime ? formatExposureTime(exposureTime) : ""}
			</td>
		</tr>
		{
			createdDate ? (
				<tr>
					<td class="small icon">
						<img
							src="/assets/img/icons/date.svg"
							alt="Created on"
						/>
					</td>
					<td colspan="5">
						<FormattedDate date={createdDate} />
					</td>
				</tr>
			) : null
		}
	</tbody>

	<style>
		/* card */
		.card {
			gap: 1.5rem;
			padding: 1.5rem;
			border-radius: 12px;
			background: rgba(255, 255, 255, 0.03);
			border: 1px solid rgba(255, 255, 255, 0.05);
			transition: 0.25s ease;
		}
		.card:hover {
			border-color: rgba(255, 255, 255, 0.15);
			transform: translateY(-2px);
		}
		.card-title {
			display: flex;
			justify-content: left; /* horizontal centering */
			align-items: top; /* vertical centering */
			padding: 0 1em;
			gap: 1em;
		}

		.card h3 {
			font-size: 1.2rem;
			margin: 0;
		}

		.card h4 {
			margin: 0.2rem 0 0.5rem;
			font-weight: 500;

			opacity: 0.7;
			font-size: 0.9rem;
			margin-bottom: 0.8rem;
			color: rgba(var(--accent));
		}

		.card-block p {
			line-height: 1.6;
			opacity: 0.9;
		}

		.card .logo {
			width: 70px;
			height: 70px;
			flex-shrink: 0;
			display: flex;
			align-items: center;
			justify-content: center;
		}
		.card .logo img {
			width: 100%;
			height: 100%;
			object-fit: contain;
		}
		.card-description {
			color: #fff;
			margin-top: -1em;
			padding: 0 1em;
		}
	</style>
</table>
